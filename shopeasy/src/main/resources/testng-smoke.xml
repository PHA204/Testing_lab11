<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite" verbose="1">

  <!--
    browser được truyền từ -Dbrowser= khi chạy Maven
    Giá trị mặc định ở đây chỉ dùng khi chạy local
    không truyền tham số
  -->
  <parameter name="browser" value="chrome"/>
  <parameter name="env"     value="dev"/>

  <test name="Login Smoke Tests">
    <groups>
      <run>
        <include name="smoke"/>
      </run>
    </groups>
    <classes>
      <class name="com.shopeasy.tests.LoginTest"/>
    </classes>
  </test>

</suite>
